{
  "name": "stem-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The Stem WebUI - Network Performance Testing - Mustard Seed Networks",
  "engines": {
    "node": ">=25.2.1",
    "npm": ">=11.7.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "vitest run --reporter=verbose --passWithNoTests",
    "test:watch": "vitest --reporter=dot",
    "test:coverage": "vitest run --coverage --reporter=verbose",
    "test:e2e": "playwright test --reporter=list",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@tanstack/react-query": "5.100.10",
    "i18next": "26.2.0",
    "i18next-browser-languagedetector": "8.2.1",
    "immer": "11.1.8",
    "lucide-react": "1.16.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "17.0.8",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@chromatic-com/storybook": "5.2.1",
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "10.4.0",
    "@storybook/addon-docs": "10.4.0",
    "@storybook/addon-onboarding": "10.4.0",
    "@storybook/addon-vitest": "10.4.0",
    "@storybook/react-vite": "10.4.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.6",
    "jsdom": "29.1.1",
    "playwright": "1.60.0",
    "postcss": "8.5.14",
    "storybook": "10.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  }
}
