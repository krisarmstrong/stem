{
  "name": "stem",
  "version": "0.1.0",
  "private": true,
  "description": "The Stem - Mustard Seed Networks",
  "type": "module",
  "engines": {
    "node": ">=25.2.1",
    "npm": ">=11.7.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "vite build",
    "lint": "biome check .",
    "lint:fix": "biome check --write --no-errors-on-unmatched .",
    "format": "biome format --write .",
    "test": "vitest",
    "security:scan": "npm audit && npx trufflehog filesystem . --fail",
    "release:patch": "npm version patch && git push --follow-tags"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*.{js,ts,tsx,md,json,css}": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
