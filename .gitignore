# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ Stem - .gitignore                                                         ║
# ╠═══════════════════════════════════════════════════════════════════════════╣
# ║ Network performance testing and orchestration platform                    ║
# ║ Stack: Go, C (DPDK), TypeScript/React (UI), Playwright                   ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ─── Application Binaries ────────────────────────────────────────────────────
/stem
/stem-*
seedtest
rfc2544-linux
*.exe
*.exe~
*.dll
*.so
*.dylib

# ─── C/DPDK Build Artifacts ──────────────────────────────────────────────────
*.o
*.a
*.obj
*.lib

# DPDK-specific
*.cmd
core.*

# Generated headers
include/version_generated.h

# ─── Build Directories ───────────────────────────────────────────────────────
/dist/
/build/
/bin/

# ─── Go Testing & Coverage ───────────────────────────────────────────────────
*.test
*.out
coverage.html
coverage.txt

# ─── Go Workspace & Dependencies ─────────────────────────────────────────────
go.work
go.work.sum
vendor/

# ─── Frontend (UI) ───────────────────────────────────────────────────────────
# Dependencies
ui/node_modules/
node_modules/

# Build outputs
ui/dist/
ui/.vite/
ui/coverage/

# Playwright test results
ui/playwright-report/
ui/test-results/

# TypeScript
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-error.log*

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.crt

# Certificates (generated at runtime)
certs/
!certs/.gitkeep

# ─── Configuration Overrides ─────────────────────────────────────────────────
# Local overrides (defaults should be version controlled)
configs/*.local.yaml
configs/*.local.json
config.yaml

# ─── Database & Runtime Data ─────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# Auto-generated/runtime data
data/

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Test Results ────────────────────────────────────────────────────────────
tests/results/
results/
reports/

# ─── Temporary Files ─────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
.tmp_*
*~

# ─── Build & Package Artifacts ───────────────────────────────────────────────
*.tar.gz
*.zip
*.deb
*.rpm

# ─── Debug & Development ─────────────────────────────────────────────────────
# Debug output
DebugImages/

# ─── AI/Agent Artifacts ──────────────────────────────────────────────────────
# AI tool session data
.claude/settings.local.json
.gemini/
CLAUDE.md
